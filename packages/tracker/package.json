{
  "name": "@mantecato/tracker",
  "version": "0.1.0",
  "description": "Lightweight analytics tracker compatible with Umami — send pageviews and custom events",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./script": "./dist/script.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "jsdom": "^29.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "analytics",
    "tracker",
    "umami",
    "pageview",
    "events"
  ],
  "license": "Apache-2.0"
}
