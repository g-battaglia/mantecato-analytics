{
  "name": "mantecato",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "./dev.sh start",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0 --port 4180",
    "dev:backend": "./backend/venv/bin/python -m uvicorn app.main:app --app-dir backend --reload --port 8100",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "cli": "cd backend && .venv/bin/python -m app.cli.main",
    "mcp": "cd backend && .venv/bin/python -m app.mcp.server"
  }
}
