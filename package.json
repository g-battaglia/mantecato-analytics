{
  "name": "mantecato",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "bin": {
    "mantecato": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0 --port 4180",
    "dev:backend": "./backend/venv/bin/python -m uvicorn app.main:app --app-dir backend --reload --port 8100",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "cli": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
