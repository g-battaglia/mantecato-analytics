# Mantecato — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (your Umami database)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret used to sign JWT session tokens (any random string)
SESSION_SECRET="change-me-to-a-random-string"

# API key for CLI/MCP authentication (generate from Settings > API Keys in the web UI)
# MANTECATO_API_KEY="mtk_..."
