# Mantecato v3 — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.

# Django secret key — MUST change in production
SECRET_KEY=change-me-to-a-random-50-char-string

# Debug mode — True for development, False for production
DEBUG=True

# Database — PostgreSQL (Mantecato's own database)
DATABASE_URL=postgres://mantecato:mantecato@localhost:5432/mantecato

# Test database — used for local development/testing
TEST_DATABASE_URL=postgres://mantecato:mantecato@localhost:5432/mantecato

# Allowed hosts — empty means all hosts are allowed ("*", the default).
# Set a comma-separated list to restrict, e.g. "mantecato.io,app.mantecato.io"
ALLOWED_HOSTS=
PRODUCTION_HOSTS=

# Trusted origins for CSRF on HTTPS deployments
# Example: https://mantecato.io,https://app.mantecato.io
CSRF_TRUSTED_ORIGINS=

# Production security toggles. Defaults are secure when DEBUG=False.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
USE_SECURE_PROXY_SSL_HEADER=True

# GeoIP — MaxMind GeoLite2-City database for IP geolocation
# Option 1: MaxMind license key (register free at https://www.maxmind.com)
MAXMIND_LICENSE_KEY=
# Option 2: Custom URL to a GeoLite2-City.tar.gz or .mmdb file
GEO_DATABASE_URL=
# Option 3: Custom path to the .mmdb file (default: ./geo/GeoLite2-City.mmdb)
GEOIP_PATH=

# Tracker — client-IP / reverse-proxy trust. The client IP feeds the cookieless
# visitor digest, so a spoofable X-Forwarded-For lets callers poison counts.
# TRUST_PROXY_HEADERS=0 ignores all forwarding headers (use REMOTE_ADDR only —
# correct when exposed directly). TRUSTED_PROXY_COUNT=N (when behind N proxies)
# reads the client spoof-resistantly from the right of X-Forwarded-For.
TRUST_PROXY_HEADERS=1
TRUSTED_PROXY_COUNT=0
# Custom single-valued client-IP header (e.g. X-Real-IP, CF-Connecting-IP).
CLIENT_IP_HEADER=

# Tracker — server-side privacy opt-out (honoured even if the JS tracker is bypassed).
# RESPECT_GPC honours Sec-GPC:1 (on by default); RESPECT_DNT honours DNT:1 (opt-in).
RESPECT_GPC=1
RESPECT_DNT=0

# Visitor dedup window (salt lifetime): day|week|month|quarter|year. Default "day"
# = no persistent identifier (Plausible-style); a longer window deduplicates
# returning visitors within it but shifts the legal basis to the consent-exempt
# audience-measurement exemption (≤13-month identifier). See docs/privacy.md.
VISITOR_EXACT_WINDOW=day
# IP precision for the visitor digest. "auto" = full IP only for the "day" window,
# /24 (IPv4) + /48 (IPv6) for any longer window (CNIL/Garante IP minimisation).
# Set integers (e.g. 24 / 48, or 32 / 128 for full IP) to override.
VISITOR_HASH_IP_PREFIX_V4=auto
VISITOR_HASH_IP_PREFIX_V6=auto

# Tracker — ingest abuse limits. Max request body bytes (legit payloads are tiny);
# per-process per-IP rate limit in requests/minute (0 disables — prefer a proxy/CDN
# limiter in production).
INGEST_MAX_BODY_BYTES=16384
INGEST_RATE_LIMIT_PER_MINUTE=0

# Optional: default language
LANGUAGE_CODE=en-us

# Optional: time zone
TIME_ZONE=UTC

# Optional: import from an existing Umami PostgreSQL database.
# The source database must be reachable from Mantecato.
UMAMI_DATABASE_URL=

# Set True to run an idempotent Umami import during Render startup.
UMAMI_IMPORT_ON_DEPLOY=False

# "data" imports analytics only. "full" also imports users, websites and reports.
UMAMI_IMPORT_MODE=data

# Required acknowledgement when UMAMI_IMPORT_MODE=full.
UMAMI_IMPORT_ALLOW_CONFIG=False

# Optional data-only import filters.
UMAMI_SOURCE_WEBSITE_ID=
MANTECATO_TARGET_WEBSITE_ID=
UMAMI_IMPORT_SINCE=
